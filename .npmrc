# Nx 23 migration (interim): @nx-dotnet/core peer-requires `nx < 23` and the
# bootstrap @abgov/nx-release@12 peer-requires `@nx/devkit ^22`. npm `overrides`
# force a version but cannot relax a declared peer *range*, so we accept the
# lagging peers here until the @nx-dotnet/core -> @nx/dotnet rewrite lands and
# @abgov/nx-release is rebuilt against Nx 23. Remove once both are resolved.
legacy-peer-deps=true
