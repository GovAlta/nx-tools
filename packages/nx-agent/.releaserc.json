{
  "extends": "../../.releaserc.json",
  "tagFormat": "nx-agent-v${version}",
  "plugins": [
    [
      "@abgov/nx-release",
      {
        "project": "nx-agent"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "pkgRoot": "dist/packages/nx-agent"
      }
    ],
    [
      "@semantic-release/github",
      {
        "releasedLabels": false,
        "successComment": false
      }
    ]
  ]
}
